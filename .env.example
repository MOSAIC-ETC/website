# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/mosaic_etc?schema=public"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# File storage — absolute path on disk; Next.js process must have read+write
STORAGE_PATH="/var/lib/mosaic-etc/storage"

# First admin (used by prisma/seed.ts on first run only)
ADMIN_EMAIL="admin@example.org"
ADMIN_PASSWORD="change-me-please"
